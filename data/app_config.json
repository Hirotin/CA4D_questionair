{
  "title": "動画アンケートスタジオ「Video Survey Studio」",
  "subtitle": "1つの質問につき7形状を順番に評価し、各形状では20手法の動画を横スクロールで比較します。「For each question, you will rate seven shapes in sequence, comparing twenty method videos per shape in a horizontally scrollable row.」動画の並び順は形状ごとにランダムです。「The twenty videos are shuffled for each shape.」",
  "slots": 20,
  "scaleLabels": ["1", "2", "3", "4", "5"],
  "scaleHints": [
    "ネガティブ「Negative」",
    "ややネガティブ「Somewhat negative」",
    "中立「Neutral」",
    "ややポジティブ「Somewhat positive」",
    "ポジティブ「Positive」"
  ],
  "mailDelivery": {
    "enabled": false,
    "smtpHost": "",
    "smtpPort": 587,
    "useStartTls": true,
    "useSsl": false,
    "username": "",
    "passwordEnv": "SURVEY_SMTP_PASSWORD",
    "fromAddress": "",
    "toAddress": "",
    "subjectPrefix": "動画アンケート結果「Video Survey Result」"
  },
  "accessControl": {
    "enabled": true,
    "password": "",
    "passwordEnv": "SURVEY_START_PASSWORD",
    "sessionTtlMinutes": 720
  },
  "videoStorage": {
    "provider": "r2",
    "publicBaseUrl": "https://pub-d59f91e9afbd4a4fb7ceea0a9d7c09bb.r2.dev",
    "publicBaseUrlEnv": "SURVEY_VIDEO_PUBLIC_BASE_URL"
  },
  "appsScriptSync": {
    "enabled": false,
    "endpointUrl": "",
    "endpointEnv": "SURVEY_APPS_SCRIPT_ENDPOINT",
    "token": "",
    "tokenEnv": "SURVEY_APPS_SCRIPT_TOKEN",
    "sheetUrl": "https://docs.google.com/spreadsheets/d/1ehpl67bOhGcxhLypC9gtTdp9yhpEuSZp9cyKKT75PT4/edit",
    "sheetUrlEnv": "SURVEY_GOOGLE_SHEET_URL",
    "timeoutSeconds": 15
  },
  "resultsR2Archive": {
    "enabled": false,
    "bucket": "",
    "bucketEnv": "R2_BUCKET_NAME",
    "endpointUrl": "",
    "endpointEnv": "R2_ENDPOINT_URL",
    "accessKey": "",
    "accessKeyEnv": "AWS_ACCESS_KEY_ID",
    "secretKey": "",
    "secretKeyEnv": "AWS_SECRET_ACCESS_KEY",
    "sessionToken": "",
    "sessionTokenEnv": "AWS_SESSION_TOKEN",
    "prefix": "survey-results",
    "prefixEnv": "SURVEY_RESULTS_R2_PREFIX",
    "regionName": "auto",
    "enabledEnv": "SURVEY_RESULTS_R2_ENABLED"
  },
  "shapeSurvey": {
    "shapeOrder": ["1013", "1047", "1143", "1189", "1230", "1232", "1445"],
    "referenceMethodCode": "0011",
    "referenceSlotLabel": "動画0「Video 0」"
  },
  "questions": [
    {
      "id": "naturalness",
      "text": "動きが自然かどうか「Please rate the naturalness of the motion」"
    },
    {
      "id": "similarity_to_video_0",
      "text": "動画0とどれだけ近いか「Please rate the similarity compared to Video 0」"
    },
    {
      "id": "shape_consistency",
      "text": "形状の一貫性「Please rate the shape consistency of the motion」"
    },
    {
      "id": "text_alignment",
      "text": "テキスト整合性「Please rate the text alignment」"
    },
    {
      "id": "method_diversity",
      "text": "各手法の多様性を1から5で評価してください。自然さとは独立に判断してください。「Please rate the diversity of each method from 1 to 5, independently of naturalness.」"
    }
  ],
  "randomVideoDatabase": {
    "path": "data/random_video_catalog_20260508_all_latest_r2.sqlite3",
    "catalogCsvPaths": [
      "data/video_catalog_20260508_all_latest_r2.csv"
    ],
    "seedVideos": []
  }
